.profile-header{-webkit-align-items:center;border-radius:20rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;padding:24rpx;-ms-flex-align:center;align-items:center;color:#fff;gap:16rpx;margin-bottom:24rpx}.profile-header--parent{background:-webkit-linear-gradient(315deg,#667eea,#764ba2);background:linear-gradient(135deg,#667eea,#764ba2)}.profile-header--child{background:-webkit-linear-gradient(315deg,#f093fb,#f5576c);background:linear-gradient(135deg,#f093fb,#f5576c)}.profile-header__avatar-wrapper{-webkit-align-items:center;background:hsla(0,0%,100%,.25);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:56rpx;width:56rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;-webkit-flex-shrink:0;justify-content:center;-ms-flex-negative:0;flex-shrink:0}.profile-header__avatar{font-size:28rpx}.profile-header__info{-webkit-flex:1;-ms-flex:1;flex:1}.profile-header__name{display:block;font-size:18rpx;font-weight:700;margin-bottom:4rpx}.profile-header__stats{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:2rpx}.profile-header__stat{font-size:13rpx;opacity:.9}.menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;background:#fff;border-bottom:1rpx solid #e8e8e8;gap:12rpx;min-height:44rpx;padding:14rpx 16rpx}.menu-item:first-child{border-radius:12rpx 12rpx 0 0}.menu-item:last-child{border-bottom:none;border-radius:0 0 12rpx 12rpx}.menu-item:only-child{border-radius:12rpx}.menu-item:active{background:rgba(0,0,0,.02)}.menu-item--danger .menu-item__title{color:#f5576c}.menu-item--danger .menu-item__icon{opacity:.8}.menu-item__icon{-webkit-flex-shrink:0;font-size:22rpx;-ms-flex-negative:0;flex-shrink:0}.menu-item__content{-webkit-flex:1;-ms-flex:1;flex:1;min-width:0}.menu-item__title{color:#333;display:block;font-size:15rpx;font-weight:500}.menu-item__subtitle{color:#888;display:block;font-size:12rpx;margin-top:2rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.menu-item__arrow{color:#bbb;-webkit-flex-shrink:0;font-size:20rpx;-ms-flex-negative:0;flex-shrink:0}@-webkit-keyframes skeleton-shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}@keyframes skeleton-shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}.profile-page__menu{margin-top:24rpx}.profile-page__referral{background:#fff;border-radius:16rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);margin-top:24rpx;padding:16rpx}.profile-page__referral-title{display:block;font-size:16rpx;font-weight:600;margin-bottom:12rpx}.profile-page__referral-stats{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;margin-bottom:16rpx}.profile-page__referral-stat{text-align:center}.profile-page__referral-value{color:#667eea;display:block;font-size:24rpx;font-weight:700}.profile-page__referral-label{color:#888;display:block;font-size:12rpx;margin-top:2rpx}.profile-page__referral-code{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;background:#f5f5f5;border-radius:12rpx;font-size:14rpx;justify-content:space-between;padding:12rpx 16rpx}.profile-page__referral-copy{-webkit-align-items:center;color:#667eea;display:-webkit-flex;display:-ms-flexbox;display:flex;font-weight:600;min-height:44rpx;min-width:44rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}